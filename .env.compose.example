# Compose runtime env template
NODE_ENV=production
PORT=8000
DATABASE_URL=file:/var/lib/apom-db/production.db
APP_PORT=80

# CORS for deployed domain
CORS_ORIGINS=https://your-domain.example

# Security and request controls
REQUEST_BODY_LIMIT=100kb
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# Auth
AUTH_JWT_SECRET=replace-with-strong-secret
SESSION_TTL_SECONDS=86400

# Optional uptime monitoring webhook
UPTIME_PING_URL=
UPTIME_PING_INTERVAL_MS=300000
